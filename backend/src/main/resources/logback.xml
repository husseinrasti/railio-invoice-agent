<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{28} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

    <!-- Agent workflow + LLM interaction logs -->
    <logger name="ai.railio.invoice" level="DEBUG"/>

    <!-- Quieten noisy Netty/Ktor internals -->
    <logger name="io.netty" level="WARN"/>
    <logger name="io.ktor.server.Application" level="INFO"/>
</configuration>
