# ---- Env ----
.env
*.local

# ---- Kotlin / Gradle ----
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!src/**/build/
*.log

# ---- Node / Next.js ----
node_modules/
.next/
out/
next-env.d.ts
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# ---- IDE / OS ----
.idea/
*.iml
.vscode/
.DS_Store

# ---- Implementation notes (never commit) ----
IMPLEMENTATION*.md
REPORT*.md

# ---- Runtime state ----
# Anchored with a leading slash on purpose: a bare `data/` matches a directory named `data` at ANY
# depth, which silently ignored the `ai/railio/invoice/data/**` source package.
/backend/data/
/data/
