# ─────────────────────────────────────────────────────────────
# Invoice Agent — environment configuration
# Copy to `.env` and adjust. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────

# ---- Ports ----
# Chosen to avoid the Railio stack, which owns 8080 (API) and 3000/3001 (dashboards) on the host.
BACKEND_PORT=8082
FRONTEND_PORT=3002

# ---- Ollama (LLM) ----
# Local-first. Ollama runs on the HOST, including under docker-compose: a container gets no GPU on
# macOS, and a 12B model does not fit in Docker's ~8GB VM (llama-server is OOM-killed, "signal:
# killed"). Compose defaults to http://host.docker.internal:11434 and reaches the host's Ollama even
# though it binds 127.0.0.1. For a host-run backend use http://localhost:11434.
# To run Ollama in Docker anyway: `docker compose --profile bundled-ollama up` and set this to
# http://ollama:11434 (use a small model and raise Docker Desktop's memory).
OLLAMA_BASE_URL=http://localhost:11434

# Which LLM backend to start on: `ollama` (local) or `openrouter` (cloud). Switchable in the UI.
LLM_PROVIDER=ollama

# ---- OpenRouter (only used when the provider is openrouter) ----
# One API over many hosted models. The base URL and model are edited in the Config UI; the API KEY
# is read from the environment ONLY — never written to config.json, never returned by the config API.
# Get a key at https://openrouter.ai/keys. A low-credit/free key can only afford small requests.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-5.2
# Free-tier rate limits. The agent refuses a run up front when the budget is spent.
OPENROUTER_RPM=10
OPENROUTER_RPD=50
# Default text model. Override with any pulled Ollama tag.
OLLAMA_MODEL=gemma4:12b

# ---- Backend API ----
# Base URL the frontend calls. Browser-side, so it must be reachable from the host.
API_URL=http://localhost:8082
# Optional shared secret. When set, the backend requires
# `Authorization: Bearer <AGENT_SECRET>` on /api/** and the frontend attaches it.
# Leave empty to disable auth (local dev default).
AGENT_SECRET=

# ---- Payment provider ----
# `mock`   — offline in-memory simulation (no Railio needed; the default for local demos).
# `railio` — propose real transfers to the Railio financial-execution API.
PAYMENT_PROVIDER=mock

# Railio API as reached from the backend. In Docker `localhost` is the container itself, so the
# host's Railio is at host.docker.internal:8080. Seeds a fresh config; the Config page owns it after.
RAILIO_BASE_URL=http://host.docker.internal:8080
RAILIO_CLIENT_ID=

# ---- Railio (only used when PAYMENT_PROVIDER=railio) ----
# Base URL, client id, and the source bank account are edited in the Config UI and stored in
# config.json. The CLIENT SECRET is read from the environment ONLY — it is never written to
# config.json and never returned by the config API. Use a secret manager in production.
# A human creates the agent credential in the Railio dashboard (Agents -> New credential); the
# secret is shown exactly once. Rotating it invalidates the old secret immediately, so a
# persistent 401 means "reload this value", not "retry".
# Scopes required: transfers:create, transfers:read (agents are never granted approve/policy scopes).
RAILIO_CLIENT_SECRET=

# ---- Mock provider tuning (ignored when PAYMENT_PROVIDER=railio) ----
# Imitates a Railio APPROVAL_THRESHOLD policy so the parked/polling path is demoable offline:
# transfers above this amount (Rial) park on AWAITING_APPROVAL, then resolve after the delay
# below as if a human approved them in the Railio dashboard.
MOCK_APPROVAL_THRESHOLD=10000000
MOCK_APPROVAL_DELAY_SECONDS=8

# ---- Frontend ----
# Public URL the browser uses to reach the backend (baked at build/runtime).
NEXT_PUBLIC_API_URL=http://localhost:8082
